{
  "name": "basemint",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "description": "BaseMint is a mobile-first Base Mini App for daily free NFT mints and reward points.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "deploy:base": "hardhat run scripts/deploy.ts --network base",
    "deploy:baseSepolia": "hardhat run scripts/deploy.ts --network baseSepolia"
  },
  "dependencies": {
    "@coinbase/wallet-sdk": "^4.3.7",
    "@metamask/connect-evm": "^2.1.1",
    "@tanstack/react-query": "^5.90.12",
    "@vercel/kv": "^3.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "15.5.20",
    "ox": "^0.9.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "viem": "^2.55.4",
    "wagmi": "^3.7.3"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.0",
    "@openzeppelin/contracts": "^5.5.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.22",
    "dotenv": "^16.6.1",
    "erc721a": "^4.3.0",
    "hardhat": "^3.11.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.10.0"
  }
}
